{
    "name": "my-mvc/framework",
    "description": "PHP 8.3+ MVC Framework with Doctrine ORM — Task Manager MVP",
    "type": "project",
    "require": {
        "php": "^8.3",
        "doctrine/orm": "^3.6",
        "symfony/cache": "^8.0"
    },
    "autoload": {
        "psr-4": {
            "snap\\": "snap/",
            "App\\": "app/"
        }
    },
    "config": {
        "optimize-autoloader": true
    },
    "minimum-stability": "stable"
}
